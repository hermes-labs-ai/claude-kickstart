{
  "permissions": {
    "defaultMode": "default",
    "disableBypassPermissionsMode": "disable",
    "disableAutoMode": "disable",
    "allow": [
      "Edit(claude-kickstart/state/**)",
      "Bash(node claude-kickstart/bin/kickstart-state.mjs init)",
      "Bash(node claude-kickstart/bin/kickstart-state.mjs doctor)",
      "Bash(node claude-kickstart/bin/kickstart-state.mjs status)",
      "Bash(node claude-kickstart/bin/kickstart-state.mjs enter)",
      "Bash(node claude-kickstart/bin/kickstart-state.mjs checkpoint awaiting_safety)",
      "Bash(node claude-kickstart/bin/kickstart-state.mjs checkpoint awaiting_self_description)",
      "Bash(node claude-kickstart/bin/kickstart-state.mjs checkpoint awaiting_self_description safest-default)",
      "Bash(node claude-kickstart/bin/kickstart-state.mjs checkpoint awaiting_self_description files-here-okay)",
      "Bash(node claude-kickstart/bin/kickstart-state.mjs checkpoint awaiting_self_description ask-every-time)",
      "Bash(node claude-kickstart/bin/kickstart-state.mjs checkpoint awaiting_history_choice)",
      "Bash(node claude-kickstart/bin/kickstart-state.mjs history-choice use-history)",
      "Bash(node claude-kickstart/bin/kickstart-state.mjs history-choice interview)",
      "Bash(node claude-kickstart/bin/kickstart-state.mjs history-scan)",
      "Bash(node claude-kickstart/bin/kickstart-state.mjs history-extract)",
      "Bash(node claude-kickstart/bin/kickstart-state.mjs portrait-verify)",
      "Bash(node claude-kickstart/bin/kickstart-state.mjs checkpoint awaiting_followup_1)",
      "Bash(node claude-kickstart/bin/kickstart-state.mjs checkpoint awaiting_followup_2)",
      "Bash(node claude-kickstart/bin/kickstart-state.mjs checkpoint awaiting_followup_3)",
      "Bash(node claude-kickstart/bin/kickstart-state.mjs checkpoint awaiting_portrait_confirmation)",
      "Bash(node claude-kickstart/bin/kickstart-state.mjs checkpoint awaiting_orientation)",
      "Bash(node claude-kickstart/bin/kickstart-state.mjs checkpoint awaiting_possibility)",
      "Bash(node claude-kickstart/bin/kickstart-state.mjs checkpoint first_action)",
      "Bash(node claude-kickstart/bin/kickstart-state.mjs complete)",
      "Bash(node claude-kickstart/bin/kickstart-state.mjs leave)",
      "Bash(node claude-kickstart/bin/kickstart-state.mjs request-reset)",
      "Bash(node claude-kickstart/bin/kickstart-state.mjs reset --confirm)",
      "Bash(node claude-kickstart/bin/kickstart-state.mjs portrait-clear --confirm)",
      "Bash(node claude-kickstart/bin/kickstart-state.mjs select-from-pending)",
      "Bash(node claude-kickstart/bin/kickstart-state.mjs evidence modified_suggestion)",
      "Bash(node claude-kickstart/bin/kickstart-state.mjs evidence corrected_assumption)",
      "Bash(node claude-kickstart/bin/kickstart-state.mjs evidence understood_file_change)",
      "Bash(node claude-kickstart/bin/kickstart-state.mjs evidence chose_scope)",
      "Bash(node claude-kickstart/bin/kickstart-state.mjs evidence requested_control)",
      "Bash(node claude-kickstart/bin/kickstart-state.mjs evidence recovered_from_error)",
      "Bash(node claude-kickstart/bin/kickstart-state.mjs evidence asked_underlying_mechanism)",
      "Bash(node claude-kickstart/bin/kickstart-state.mjs guidance adaptive)",
      "Bash(node claude-kickstart/bin/kickstart-state.mjs guidance simpler)",
      "Bash(node claude-kickstart/bin/kickstart-state.mjs guidance advanced)"
    ],
    "ask": [
      "WebFetch",
      "WebSearch"
    ],
    "deny": [
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.config/gcloud/**)",
      "Read(~/.gnupg/**)",
      "Read(~/.kube/**)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Edit(~/.ssh/**)",
      "Edit(~/.aws/**)",
      "Edit(~/.config/gcloud/**)",
      "Edit(~/.gnupg/**)",
      "Edit(~/.kube/**)",
      "Edit(**/.env)",
      "Edit(**/.env.*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "node claude-kickstart/bin/kickstart-state.mjs hook-context",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node claude-kickstart/bin/kickstart-state.mjs session-end",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
